<view class="tabbar">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab {{selected === index ? 'active' : ''}}"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab">
    <view class="icon">{{item.icon}}</view>
    <view class="label">{{item.text}}</view>
  </view>
</view>
