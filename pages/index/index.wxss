.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 20rpx;
  padding-top: 160rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.badge {
  letter-spacing: 8rpx;
  color: var(--primary);
  font-weight: 700;
  font-size: 24rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
}

.sub {
  color: var(--text-dim);
  font-size: 28rpx;
  text-align: center;
  max-width: 520rpx;
  line-height: 1.5;
}

.stat {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin: 40rpx 0;
}

.stat-num {
  font-size: 72rpx;
  font-weight: 800;
  background: linear-gradient(135deg, var(--primary), var(--primary-2));
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.stat-label {
  color: var(--text-dim);
}

.hero .btn-primary {
  width: 60%;
  margin-top: 20rpx;
}

.btn-ghost {
  width: 60%;
  margin-top: 18rpx;
  background: var(--surface);
  color: var(--text);
  border: 1rpx solid var(--border);
  border-radius: var(--radius);
  padding: 22rpx 0;
  text-align: center;
  font-weight: 600;
}

.btn-ghost:active {
  transform: scale(0.98);
}

/* 云端连接状态卡片 */
.cloud-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 86%;
  padding: 22rpx 26rpx;
  margin: 14rpx 0 30rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20px);
}

.cloud-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #9ca3af;
  flex-shrink: 0;
}

.cloud-ok .cloud-dot {
  background: #34d399;
  box-shadow: 0 0 12rpx #34d399;
}

.cloud-error .cloud-dot {
  background: #f87171;
  box-shadow: 0 0 12rpx #f87171;
}

.cloud-pending .cloud-dot {
  background: #fbbf24;
  animation: cloudPulse 1.2s ease-in-out infinite;
}

@keyframes cloudPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.cloud-text {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.cloud-title {
  font-size: 26rpx;
  color: #e8eaf0;
}

.cloud-sub {
  font-size: 22rpx;
  color: rgba(232, 234, 240, 0.6);
  margin-top: 4rpx;
}

.cloud-retry {
  margin: 0;
  background: #6d5efc;
  color: #fff;
  font-size: 22rpx;
}
