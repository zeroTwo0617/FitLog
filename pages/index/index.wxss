.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 20rpx;
  padding-top: 160rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  position: relative;
}

/* soft brand glow behind the badge for depth */
.hero::before {
  content: "";
  position: absolute;
  top: 120rpx;
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79, 140, 255, 0.18), transparent 70%);
  filter: blur(10rpx);
  pointer-events: none;
}

.badge {
  position: relative;
  letter-spacing: 8rpx;
  color: var(--primary);
  font-weight: 700;
  font-size: 24rpx;
}

.title {
  position: relative;
  font-size: 60rpx;
  font-weight: 800;
  background: linear-gradient(180deg, #ffffff, #c9d4ff);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.sub {
  position: relative;
  color: var(--text-dim);
  font-size: 28rpx;
  text-align: center;
  max-width: 520rpx;
  line-height: 1.5;
}

.hero .btn-primary {
  position: relative;
  width: 64%;
  margin-top: 40rpx;
}
