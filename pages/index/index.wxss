.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 20rpx;
  padding-top: 160rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.badge {
  letter-spacing: 8rpx;
  color: var(--primary);
  font-weight: 700;
  font-size: 24rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
}

.sub {
  color: var(--text-dim);
  font-size: 28rpx;
  text-align: center;
  max-width: 520rpx;
  line-height: 1.5;
}

.hero .btn-primary {
  width: 60%;
  margin-top: 40rpx;
}
