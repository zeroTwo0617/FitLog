.page.history { padding-bottom: 60rpx; }

.list { display: flex; flex-direction: column; gap: var(--gap); }

.card { transition: transform 0.2s ease, border-color 0.2s ease; }
.card:active { transform: scale(0.99); border-color: var(--primary); }

.card-top { display: flex; justify-content: space-between; align-items: baseline; }
.date { font-size: 32rpx; font-weight: 600; }
.count { color: var(--text-dim); font-size: 24rpx; }
.names { margin-top: 12rpx; color: var(--text); font-size: 28rpx; line-height: 1.5; }
