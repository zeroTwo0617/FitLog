.search { margin-bottom: 20rpx; }
.cats { white-space: nowrap; margin-bottom: 20rpx; }

.list { display: flex; flex-direction: column; gap: 16rpx; }

.card { transition: transform 0.2s ease, border-color 0.2s ease; }
.card:active { transform: scale(0.99); border-color: var(--primary); }

.card-top { display: flex; justify-content: space-between; align-items: center; }
.name { font-size: 30rpx; font-weight: 600; }
.chev { color: var(--primary); font-size: 24rpx; }
.meta { color: var(--text-dim); font-size: 24rpx; margin-top: 8rpx; }

.steps {
  margin-top: 18rpx; padding-top: 18rpx;
  border-top: 1rpx solid var(--border);
  display: flex; flex-direction: column; gap: 12rpx;
}
.step { display: flex; gap: 14rpx; }
.step-no {
  flex: none; width: 36rpx; height: 36rpx; border-radius: 50%;
  background: var(--surface-2); color: var(--primary);
  font-size: 22rpx; text-align: center; line-height: 36rpx;
}
.step-txt { flex: 1; color: var(--text); font-size: 26rpx; line-height: 1.5; }
