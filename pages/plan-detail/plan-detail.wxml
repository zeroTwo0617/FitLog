<view class="page detail">
  <view class="head" wx:if="{{plan}}">
    <text class="d-name">{{plan.name}}</text>
    <text class="d-sub">{{plan.items.length}} 个动作</text>
  </view>

  <view class="items" wx:if="{{plan}}">
    <view class="d-item" wx:for="{{plan.items}}" wx:key="exerciseId">
      <text class="d-ex">{{item.exerciseName}}</text>
      <view class="d-targets">
        <text class="d-chip" wx:if="{{item.targetSets}}">{{item.targetSets}} 组</text>
        <text class="d-chip" wx:if="{{item.targetReps}}">{{item.targetReps}} 次</text>
        <text class="d-chip" wx:if="{{item.targetWeight}}">{{item.targetWeight}} kg</text>
        <text class="d-chip dim" wx:if="{{!item.targetSets && !item.targetReps && !item.targetWeight}}">无目标</text>
      </view>
    </view>
  </view>

  <button class="btn-start" bindtap="startTraining" wx:if="{{plan}}">开始训练</button>
</view>
