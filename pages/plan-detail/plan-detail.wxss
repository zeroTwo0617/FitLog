.d-name { display: block; font-size: 48rpx; font-weight: 700; }
.d-sub { display: block; margin-top: 12rpx; color: var(--text-dim); font-size: 26rpx; }

.items { display: flex; flex-direction: column; gap: 18rpx; }
/* 动作项：外观由全局 .card 提供 */
.d-item { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.d-ex { font-size: 32rpx; font-weight: 600; flex: 1; min-width: 0; }
.d-targets { display: flex; gap: 10rpx; flex-shrink: 0; }
.d-chip {
  font-size: 22rpx; padding: 8rpx 16rpx; border-radius: 999rpx;
  background: rgba(79, 140, 255, 0.18); color: #9ec1ff; white-space: nowrap;
}
.d-chip.dim { background: rgba(255, 255, 255, 0.06); color: var(--text-dim); }

.btn-start { margin-top: 40rpx; }
