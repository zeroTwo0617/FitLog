.head {
  margin-bottom: 28rpx;
}

.h-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
}

.h-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text-dim);
}

.card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 22rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 22rpx;
}

/* 表单 */
.field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-bottom: 20rpx;
}

.fl {
  font-size: 28rpx;
  color: var(--text-dim);
}

.fv {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.g-item {
  width: calc(50% - 8rpx);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.gl {
  font-size: 22rpx;
  color: var(--text-dim);
}

.gi {
  background: rgba(0, 0, 0, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  font-size: 28rpx;
  color: var(--text);
}

.note {
  margin-top: 18rpx;
  background: rgba(0, 0, 0, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  color: var(--text);
}

.btn-save {
  margin-top: 24rpx;
  width: 100%;
  background: linear-gradient(135deg, var(--primary), var(--primary-2));
  color: #fff;
  font-weight: 600;
  border-radius: var(--radius);
  padding: 22rpx 0;
}

.btn-save[disabled] {
  opacity: 0.6;
}

/* 体重趋势 */
.chart {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  height: 220rpx;
}

.bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
}

.bar {
  width: 100%;
  min-height: 4rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: linear-gradient(180deg, var(--primary), var(--primary-2));
  transition: height 0.4s ease;
}

.bar-day {
  margin-top: 8rpx;
  font-size: 16rpx;
  color: var(--text-dim);
  white-space: nowrap;
}

/* 历史列表 */
.rec {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.rec:last-child {
  border-bottom: none;
}

.rec-date {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
}

.rec-vals {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.rv {
  font-size: 22rpx;
  color: var(--text-dim);
  background: rgba(255, 255, 255, 0.06);
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
}

/* 空态 */
.empty {
  text-align: center;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.empty-emoji {
  font-size: 72rpx;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
}

.empty-sub {
  font-size: 24rpx;
  color: var(--text-dim);
}
