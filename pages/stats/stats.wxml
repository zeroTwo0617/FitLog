<view class="page tab-page">
  <view class="head">
    <text class="h-title">数据统计</text>
    <text class="h-sub">训练量、打卡与力量成长，一目了然</text>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中…</view>

  <block wx:if="{{!loading}}">
    <!-- 摘要卡 -->
    <view class="summary" wx:if="{{hasData}}">
      <view class="sum-card">
        <text class="sum-num">{{totalWorkouts}}</text>
        <text class="sum-label">次训练</text>
      </view>
      <view class="sum-card">
        <text class="sum-num">{{totalVolume}}</text>
        <text class="sum-label">总容量(kg)</text>
      </view>
      <view class="sum-card">
        <text class="sum-num">{{monthCheckins}}</text>
        <text class="sum-label">本月打卡</text>
      </view>
    </view>

    <view class="empty" wx:if="{{!hasData}}">
      <text class="empty-emoji">📊</text>
      <text class="empty-text">还没有训练数据</text>
      <text class="empty-sub">去首页「开始训练」记录第一练吧</text>
    </view>

    <!-- 训练量趋势 -->
    <view class="card" wx:if="{{hasData}}">
      <text class="card-title">近 14 天训练量</text>
      <view class="chart">
        <view class="bar-col" wx:for="{{trend}}" wx:key="dateStr">
          <view class="bar {{item.trained ? 'bar-on' : ''}}" style="height:{{item.heightPct}}%"></view>
          <text class="bar-day">{{item.day}}</text>
        </view>
      </view>
    </view>

    <!-- 打卡日历 -->
    <view class="card" wx:if="{{hasData}}">
      <text class="card-title">{{calYear}} 年 {{calMonth}} 月 · 打卡</text>
      <view class="cal-week">
        <text wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this" class="cal-wd">{{item}}</text>
      </view>
      <view class="cal-grid">
        <view wx:for="{{calendar}}" wx:key="dateStr" class="cal-cell {{item.trained ? 'on' : ''}} {{item.isToday ? 'today' : ''}}">
          <text>{{item.day}}</text>
        </view>
      </view>
    </view>

    <!-- 动作最大重量 Top5 -->
    <view class="card" wx:if="{{maxByExercise.length > 0}}">
      <text class="card-title">动作最大重量 Top 5</text>
      <view class="ex-list">
        <view class="ex-row" wx:for="{{maxByExercise}}" wx:key="name">
          <text class="ex-name">{{item.name}}</text>
          <view class="ex-bar-wrap">
            <view class="ex-bar" style="width:{{item.heightPct}}%"></view>
          </view>
          <text class="ex-val">{{item.max}}kg</text>
        </view>
      </view>
    </view>

    <!-- 身体数据入口 -->
    <view class="card link-card" bindtap="goBody">
      <text class="lc-label">身体数据</text>
      <text class="lc-sub">记录体重 / 体脂 / 围度</text>
      <text class="lc-arrow">›</text>
    </view>
  </block>
</view>
