/* 摘要卡 */
.summary { display: flex; gap: 16rpx; margin-bottom: 28rpx; }
.sum-card {
  flex: 1;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  padding: 24rpx 12rpx;
  border-radius: var(--radius);
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
}
.sum-num {
  font-size: 40rpx; font-weight: 800;
  background: linear-gradient(135deg, var(--primary), var(--primary-2));
  -webkit-background-clip: text; background-clip: text; color: transparent;
}
.sum-label { font-size: 22rpx; color: var(--text-dim); }

/* 训练量柱状图 */
.chart { display: flex; align-items: flex-end; gap: 8rpx; height: 240rpx; }
.bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; height: 100%; justify-content: flex-end; }
.bar {
  width: 100%; min-height: 4rpx; border-radius: 8rpx 8rpx 0 0;
  background: rgba(79, 140, 255, 0.25);
  transition: height 0.4s ease;
}
.bar-on {
  background: linear-gradient(180deg, var(--primary), var(--primary-2));
  box-shadow: var(--shadow-glow);
}
.bar-day { margin-top: 8rpx; font-size: 18rpx; color: var(--text-dim); }

/* 日历 */
.cal-week { display: flex; margin-bottom: 12rpx; }
.cal-wd { flex: 1; text-align: center; font-size: 22rpx; color: var(--text-dim); }
.cal-grid { display: flex; flex-wrap: wrap; }
.cal-cell {
  width: 14.28%; height: 76rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: var(--text-dim);
  box-sizing: border-box;
}
.cal-cell.on { color: #fff; font-weight: 700; }
.cal-cell.on text {
  width: 56rpx; height: 56rpx; line-height: 56rpx; text-align: center;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-2));
  box-shadow: 0 4rpx 14rpx rgba(79, 140, 255, 0.4);
}
.cal-cell.today text { border: 2rpx solid var(--primary-2); }

/* 最大重量 Top5 */
.ex-list { display: flex; flex-direction: column; gap: 18rpx; }
.ex-row { display: flex; align-items: center; gap: 14rpx; }
.ex-name { width: 160rpx; font-size: 26rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ex-bar-wrap { flex: 1; height: 18rpx; background: rgba(255, 255, 255, 0.08); border-radius: 999rpx; overflow: hidden; }
.ex-bar { height: 100%; border-radius: 999rpx; background: linear-gradient(90deg, var(--primary), var(--primary-2)); }
.ex-val { width: 96rpx; text-align: right; font-size: 24rpx; color: var(--text); }

/* 身体数据入口 */
.link-card { display: flex; align-items: center; gap: 16rpx; }
.lc-label { font-size: 30rpx; font-weight: 600; }
.lc-sub { flex: 1; font-size: 24rpx; color: var(--text-dim); }
.lc-arrow { font-size: 36rpx; color: var(--text-dim); }
