/* 计划名称：外观由全局 .card 提供 */
.field { display: flex; flex-direction: column; gap: 14rpx; }
.label { font-size: 26rpx; color: var(--text-dim); }
.name-inp { font-size: 34rpx; font-weight: 600; color: var(--text); }

.sec-title { margin: 36rpx 4rpx 18rpx; font-size: 28rpx; font-weight: 600; color: var(--text-dim); }

.items { display: flex; flex-direction: column; gap: 18rpx; }
/* 动作项：外观由全局 .card 提供 */
.item-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18rpx; }
.item-name { font-size: 32rpx; font-weight: 600; }
.item-del { font-size: 24rpx; color: var(--danger); }

.targets { display: flex; gap: 16rpx; }
.tg { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.tg-label { font-size: 22rpx; color: var(--text-dim); }
.tg-inp {
  background: rgba(0, 0, 0, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  font-size: 28rpx;
  text-align: center;
  color: var(--text);
}

.btn-add { margin-top: 28rpx; }

/* 动作选择器：底部弹出遮罩面板（fixed，保留模糊） */
.picker-mask {
  position: fixed; left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 100;
  display: flex; flex-direction: column; justify-content: flex-end;
}
.sheet {
  background: #16181d;
  border-radius: 28rpx 28rpx 0 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  padding: 8rpx 28rpx 28rpx;
  max-height: 82vh;
  display: flex; flex-direction: column;
  box-sizing: border-box;
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  backdrop-filter: blur(24px) saturate(180%);
}
.sheet-handle {
  width: 72rpx; height: 8rpx; border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.25);
  margin: 10rpx auto 18rpx;
}
.search { margin-bottom: 16rpx; flex-shrink: 0; }
.cats { white-space: nowrap; margin-bottom: 16rpx; flex-shrink: 0; }
.pick-list { max-height: 56vh; flex: 1; }
.pick-item { display: flex; flex-direction: column; gap: 6rpx; padding: 22rpx 8rpx; border-bottom: 1rpx solid rgba(255, 255, 255, 0.08); }
.pick-item:active { background: var(--surface-2); }
.pick-name { font-size: 30rpx; }
.pick-meta { font-size: 22rpx; color: var(--text-dim); }

.btn-save { margin-top: 36rpx; }
