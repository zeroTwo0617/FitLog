.list { display: flex; flex-direction: column; gap: 20rpx; }

.card { display: flex; align-items: center; gap: 16rpx; transition: transform 0.2s ease, border-color 0.2s ease; }
.card:active { transform: scale(0.99); border-color: var(--primary); }

.card-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8rpx; }
.card-name { font-size: 34rpx; font-weight: 600; }
.card-meta { font-size: 24rpx; color: var(--text-dim); }
.card-arrow { color: var(--text-dim); font-size: 40rpx; }

.btn-primary { margin-top: 40rpx; }
