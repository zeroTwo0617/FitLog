<view class="page tab-page">
  <view class="head">
    <text class="h-title">训练计划</text>
    <text class="h-sub">保存常用动作组合，一键开始训练</text>
  </view>

  <view class="list" wx:if="{{list.length > 0}}">
    <view class="card" wx:for="{{list}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
      <view class="card-main">
        <text class="card-name">{{item.name}}</text>
        <text class="card-meta">{{item.count}} 个动作 · {{item.namesText}}</text>
      </view>
      <text class="card-arrow">›</text>
    </view>
  </view>

  <view class="empty" wx:if="{{list.length === 0 && !loading}}">
    <text class="empty-emoji">📋</text>
    <text class="empty-text">还没有计划</text>
    <text class="empty-sub">点下方按钮，创建你的第一个训练模板</text>
  </view>

  <button class="btn-primary" bindtap="goCreate">+ 新建计划</button>
</view>
