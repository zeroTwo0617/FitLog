<view class="page detail">
  <view class="loading" wx:if="{{loading}}">加载中…</view>

  <block wx:if="{{!loading && workout}}">
    <view class="head">
      <text class="date">{{workout.dateStr}}</text>
      <text class="summary">{{groups.length}} 个动作 · {{workout.setTotal}} 组</text>
    </view>

    <view class="group" wx:for="{{groups}}" wx:key="exerciseId">
      <view class="group-head">
        <text class="g-name">{{item.name}}</text>
        <text class="g-count">{{item.setCount}} 组</text>
      </view>
      <view class="set-row" wx:for="{{item.sets}}" wx:for-item="s" wx:for-index="si" wx:key="setIndex">
        <text class="c-no">{{s.setIndex}}</text>
        <text class="c-reps">{{s.repsText}}</text>
        <text class="c-weight">{{s.weightText}}</text>
        <text class="c-rest">{{s.restText}}</text>
      </view>
    </view>
  </block>

  <view class="empty" wx:if="{{!loading && !workout}}">
    <text>未找到该训练记录</text>
  </view>
</view>
