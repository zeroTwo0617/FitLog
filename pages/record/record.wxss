.page.record { padding-bottom: 60rpx; }

/* 顶部栏 */
.topbar {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 28rpx;
}
.topbar .date { color: var(--text-dim); font-size: 26rpx; }
.topbar .title { font-size: 44rpx; font-weight: 700; }

/* 计划导入条 */
.plan-bar { margin-bottom: 24rpx; }
.plan-bar.on {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 22rpx;
  background: var(--primary-soft);
  border: 1rpx solid var(--primary);
  border-radius: var(--radius);
}
.plan-on-name { font-size: 26rpx; color: var(--text); font-weight: 600; }
.plan-on-clear { font-size: 24rpx; color: var(--text-dim); }

/* 训练动作卡片（外观由全局 .card 提供） */
.session { display: flex; flex-direction: column; gap: var(--gap); }
.ex-card { transition: border-color 0.2s ease, transform 0.2s ease; }
.ex-card:active { transform: scale(0.995); border-color: var(--primary); }

.ex-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}
.ex-name { font-size: 30rpx; font-weight: 600; }
.ex-del { color: var(--danger); font-size: 24rpx; }

/* 跟练目标参照 */
.ex-target {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: var(--primary);
}

.set-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 0;
}
.set-row.head {
  color: var(--text-dim);
  font-size: 22rpx;
  border-bottom: 1rpx solid var(--border);
  margin-bottom: 4rpx;
}
.c-no { width: 56rpx; text-align: center; color: var(--text-dim); font-size: 24rpx; flex: none; }
.c-reps, .c-weight, .c-rest { flex: 1; text-align: center; font-size: 22rpx; color: var(--text-dim); }
.c-op { width: 48rpx; text-align: center; flex: none; }

.inp {
  flex: 1;
  min-width: 0;
  background: var(--surface-2);
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  padding: 12rpx 0;
  color: var(--text);
  font-size: 28rpx;
  text-align: center;
}
.del { color: var(--danger); font-size: 34rpx; }

.add-set {
  margin: 14rpx 0 0;
  background: transparent;
  color: var(--primary);
  border: 1rpx solid var(--border);
  font-size: 24rpx;
}

/* 空态 */
.empty { text-align: center; color: var(--text-dim); padding: 100rpx 40rpx; font-size: 28rpx; line-height: 1.6; }

.btn-add { margin: 32rpx 0 20rpx; }

/* 动作选择器 / 计划选择器：底部弹出遮罩面板（fixed，保留模糊） */
.picker-mask, .plan-picker-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.sheet, .plan-sheet {
  background: #16181d;
  border-radius: 28rpx 28rpx 0 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  padding: 8rpx 28rpx 28rpx;
  max-height: 82vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  backdrop-filter: blur(24px) saturate(180%);
}
.sheet-handle {
  width: 72rpx; height: 8rpx; border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.25);
  margin: 10rpx auto 18rpx;
}
.search { margin-bottom: 16rpx; flex-shrink: 0; }
.cats { white-space: nowrap; margin-bottom: 16rpx; flex-shrink: 0; }
.pick-list { max-height: 56vh; flex: 1; }

.sheet-title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; flex-shrink: 0; }
.plan-pick-list { max-height: 56vh; flex: 1; }
.plan-pick-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 8rpx;
  border-bottom: 1rpx solid var(--border);
}
.plan-pick-item:active { background: var(--surface-2); }
.pp-name { font-size: 30rpx; color: var(--text); }
.pp-meta { font-size: 22rpx; color: var(--text-dim); }
.plan-empty { text-align: center; color: var(--text-dim); padding: 60rpx 20rpx; font-size: 26rpx; }
.pp-cancel {
  margin-top: 18rpx;
  background: var(--surface-2);
  color: var(--text-dim);
  border: 1rpx solid var(--border);
  border-radius: var(--radius);
  font-size: 28rpx;
  padding: 18rpx 0;
  flex-shrink: 0;
}

.pick-item {
  display: flex; flex-direction: column; gap: 4rpx;
  padding: 18rpx 12rpx;
  border-bottom: 1rpx solid var(--border);
}
.pick-item:active { background: var(--surface-2); }
.pick-name { font-size: 28rpx; color: var(--text); }
.pick-meta { font-size: 22rpx; color: var(--text-dim); }

.btn-save { margin-top: 12rpx; }
